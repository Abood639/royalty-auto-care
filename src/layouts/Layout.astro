---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Premium mobile detailing, paint correction, and certified System X ceramic coatings serving Valrico, Tampa & Brandon FL. The royal treatment for your car." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://royaltyautocare.net').href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>document.documentElement.classList.add('js')</script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title} | Royalty Auto Care</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Royalty Auto Care`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://royaltyautocare.net/" />
    
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        document.body.classList.add('js');
      });
    </script>

    <!-- Fonts & Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  </head>
  <body>
    <canvas id="rain-canvas"></canvas>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    
    <script>
      function initApp() {
        // Scroll animations & IntersectionObserver
        const observerOptions = {
          root: null,
          rootMargin: "0px -10% -10% 0px", // triggers slightly before entering viewport fully
          threshold: 0.05
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        const animatedElements = document.querySelectorAll(".animate-on-scroll");
        animatedElements.forEach(el => observer.observe(el));

        // Background rain canvas animation
        const canvas = document.getElementById('rain-canvas') as HTMLCanvasElement;
        if (!canvas) return;

        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        let width = (canvas.width = window.innerWidth);
        let height = (canvas.height = window.innerHeight);

        const handleResize = () => {
          width = canvas.width = window.innerWidth;
          height = canvas.height = window.innerHeight;
        };
        window.addEventListener('resize', handleResize, { passive: true });

        // Pre-render the glowing neon car once on an offscreen canvas.
        // This eliminates expensive path computation, shadowBlur, and filter blurs inside the 60fps loop.
        const offscreen = document.createElement('canvas');
        const ow = 80;  // Master canvas width (includes glow padding)
        const oh = 140; // Master canvas height (includes glow padding)
        offscreen.width = ow;
        offscreen.height = oh;
        const octx = offscreen.getContext('2d');
        
        if (octx) {
          const cx = ow / 2;
          const cy = oh / 2;
          const carW = 32;
          const carH = 70;
          const x = cx - carW / 2;
          const y = cy - carH / 2;
          const hw = carW / 2;

          // Draw the paths on the offscreen canvas
          octx.beginPath();
          
          // Silhouette
          octx.moveTo(x + hw * 0.3, y + carH * 0.05);
          octx.lineTo(x + carW - hw * 0.3, y + carH * 0.05);
          octx.quadraticCurveTo(x + carW - hw * 0.1, y + carH * 0.15, x + carW - hw * 0.15, y + carH * 0.28);
          octx.lineTo(x + carW - hw * 0.25, y + carH * 0.5);
          octx.quadraticCurveTo(x + carW - hw * 0.1, y + carH * 0.65, x + carW - hw * 0.25, y + carH * 0.8);
          octx.quadraticCurveTo(x + carW - hw * 0.4, y + carH * 0.98, x + hw, y + carH);
          octx.quadraticCurveTo(x + hw * 0.4, y + carH * 0.98, x + hw * 0.25, y + carH * 0.8);
          octx.quadraticCurveTo(x + hw * 0.1, y + carH * 0.65, x + hw * 0.25, y + carH * 0.5);
          octx.lineTo(x + hw * 0.15, y + carH * 0.28);
          octx.quadraticCurveTo(x + hw * 0.1, y + carH * 0.15, x + hw * 0.3, y + carH * 0.05);

          // Side mirrors
          octx.moveTo(x + hw * 0.22, y + carH * 0.52);
          octx.lineTo(x - hw * 0.05, y + carH * 0.5);
          octx.lineTo(x, y + carH * 0.46);
          octx.lineTo(x + hw * 0.24, y + carH * 0.48);

          octx.moveTo(x + carW - hw * 0.22, y + carH * 0.52);
          octx.lineTo(x + carW + hw * 0.05, y + carH * 0.5);
          octx.lineTo(x + carW, y + carH * 0.46);
          octx.lineTo(x + carW - hw * 0.24, y + carH * 0.48);

          // Cabin
          octx.moveTo(x + hw * 0.55, y + carH * 0.62);
          octx.lineTo(x + carW - hw * 0.55, y + carH * 0.62);
          octx.quadraticCurveTo(x + carW - hw * 0.45, y + carH * 0.72, x + hw, y + carH * 0.74);
          octx.quadraticCurveTo(x + hw * 0.45, y + carH * 0.72, x + hw * 0.55, y + carH * 0.62);

          octx.moveTo(x + hw * 0.55, y + carH * 0.62);
          octx.lineTo(x + hw * 0.6, y + carH * 0.38);
          octx.lineTo(x + carW - hw * 0.6, y + carH * 0.38);
          octx.lineTo(x + carW - hw * 0.55, y + carH * 0.62);

          octx.moveTo(x + hw * 0.6, y + carH * 0.38);
          octx.quadraticCurveTo(x + hw, y + carH * 0.32, x + carW - hw * 0.6, y + carH * 0.38);
          octx.lineTo(x + carW - hw * 0.65, y + carH * 0.25);
          octx.lineTo(x + hw * 0.65, y + carH * 0.25);
          octx.lineTo(x + hw * 0.6, y + carH * 0.38);

          // Spoiler
          octx.moveTo(x + hw * 0.2, y + carH * 0.01);
          octx.lineTo(x + carW - hw * 0.2, y + carH * 0.01);
          octx.lineTo(x + carW - hw * 0.25, y + carH * 0.06);
          octx.lineTo(x + hw * 0.25, y + carH * 0.06);
          octx.lineTo(x + hw * 0.2, y + carH * 0.01);

          octx.moveTo(x + hw * 0.6, y + carH * 0.06);
          octx.lineTo(x + hw * 0.6, y + carH * 0.01);
          octx.moveTo(x + carW - hw * 0.6, y + carH * 0.06);
          octx.lineTo(x + carW - hw * 0.6, y + carH * 0.01);

          // First stroke: Neon glow outline
          octx.strokeStyle = 'rgba(224, 76, 228, 0.8)';
          octx.lineWidth = 4;
          octx.shadowColor = '#e04ce4';
          octx.shadowBlur = 15;
          octx.stroke();

          // Second stroke: High intensity neon white-pink core
          octx.strokeStyle = '#ffffff';
          octx.lineWidth = 1.5;
          octx.shadowBlur = 0; // Keep core sharp
          octx.stroke();
        }

        interface CarParticle {
          x: number;
          y: number;
          w: number;
          h: number;
          speed: number;
          scale: number;
          opacity: number;
        }

        const particles: CarParticle[] = [];
        const maxParticles = 20;

        function createParticle(initY = false): CarParticle {
          const scale = Math.random() * 0.65 + 0.35; // 0.35 to 1.0
          const w = ow * scale;
          const h = oh * scale;
          return {
            x: Math.random() * width,
            y: initY ? Math.random() * height : -h - 40,
            w,
            h,
            speed: (Math.random() * 1.4 + 0.8) * scale,
            scale,
            opacity: (Math.random() * 0.28 + 0.17) * scale // high visibility
          };
        }

        for (let i = 0; i < maxParticles; i++) {
          particles.push(createParticle(true));
        }

        let animationFrameId: number;

        function animate() {
          ctx.clearRect(0, 0, width, height);

          for (let i = 0; i < particles.length; i++) {
            const p = particles[i];
            p.y += p.speed;

            if (p.y > height + 40) {
              particles[i] = createParticle(false);
              continue;
            }

            ctx.save();
            ctx.globalAlpha = p.opacity;
            // Draw pre-rendered glow image directly (extremely fast hardware acceleration)
            ctx.drawImage(offscreen, p.x, p.y, p.w, p.h);
            ctx.restore();
          }

          animationFrameId = requestAnimationFrame(animate);
        }

        animate();

        return () => {
          if (animationFrameId) {
            cancelAnimationFrame(animationFrameId);
          }
          window.removeEventListener('resize', handleResize);
        };
      }

      // Safe immediate or deferred execution
      let cleanup: (() => void) | undefined;
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          cleanup = initApp();
        });
      } else {
        cleanup = initApp();
      }

      // Handle page cleanup on Astro transition
      document.addEventListener('astro:before-preparation', () => {
        if (cleanup) {
          cleanup();
          cleanup = undefined;
        }
      });
    </script>
    
    <style is:global>
      #rain-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: -1;
        pointer-events: none;
        background: transparent;
      }

      /* IntersectionObserver fade-in states */
      .animate-on-scroll {
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      
      .js .animate-on-scroll {
        opacity: 0;
        transform: translateY(30px);
      }
      
      .animate-on-scroll.is-visible {
        opacity: 1;
        transform: translateY(0);
      }
      
      /* Delay utility classes */
      .delay-100 { transition-delay: 100ms; }
      .delay-200 { transition-delay: 200ms; }
      .delay-300 { transition-delay: 300ms; }
      .delay-400 { transition-delay: 400ms; }
    </style>
  </body>
</html>
