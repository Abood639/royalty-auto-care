---
import Layout from '../layouts/Layout.astro';
import NeonCard from '../components/NeonCard.astro';

const wrapServices = [
  {
    name: "Full Vehicle Wrap",
    carsPrice: "Starting at $2,999",
    trucksPrice: "Starting at $4,199",
    desc: "Transform your vehicle's entire appearance with a high-grade vinyl wrap. Available in gloss, satin, matte, metallic, and color-shifting finishes. Protects underlying paint while delivering a custom aesthetic.",
    icon: "fa-solid fa-car"
  },
  {
    name: "Chrome Delete",
    carsPrice: "Starting at $499",
    trucksPrice: "Starting at $599",
    desc: "Conceal reflective chrome trim elements with sleek gloss, satin, or matte black vinyl. Applies to window borders, grill surrounds, mirror caps, and side badges for a modern stealth aesthetic.",
    icon: "fa-solid fa-eye-slash"
  },
  {
    name: "Roof Wrap",
    carsPrice: "Starting at $449",
    trucksPrice: "Starting at $549",
    desc: "Create a dramatic panoramic glass look or contrast effect by wrapping the roof surface. Popular styling choice using gloss black or carbon fiber vinyl.",
    icon: "fa-solid fa-arrows-up-down"
  },
  {
    name: "Hood Wrap",
    carsPrice: "Starting at $449",
    trucksPrice: "Starting at $549",
    desc: "Add a sporty accent to your vehicle's front profile by wrapping the hood surface. Protects the leading edge from light road debris.",
    icon: "fa-solid fa-mask"
  }
];

const smallWraps = [
  {
    name: "Mirror Wrap",
    price: "Starting at $149",
    desc: "Wrap side mirror covers to add contrasting highlights or accent colors."
  },
  {
    name: "Pillar Wrap",
    price: "Starting at $149",
    desc: "Wrap window pillars (A, B, or C pillars) to restore sun-damaged trim or add a sleek dark finish."
  }
];

const partialExamples = [
  "Racing Stripes",
  "Accent Pieces",
  "Business Branding",
  "Hood Graphics",
  "Rocker Panels",
  "Custom Vinyl Graphics"
];
---

<Layout 
  title="Professional Vinyl Wraps & Custom Styling" 
  description="Transform your vehicle with premium full color wraps, chrome delete, roof/hood accents, and wrap removal services in Tampa, Valrico, and Brandon FL."
>
  <!-- Page Header -->
  <section class="page-header-section">
    <div class="container page-header-grid animate-fade-in">
      <div class="page-header-content">
        <span class="eyebrow">CUSTOM STYLING</span>
        <h1>Vinyl Wrap Services</h1>
        <p>Give your vehicle a completely new look with our high-grade vinyl wrap installations. From full-color transformations to subtle accents like chrome deletes and roof wraps, we use premium films to deliver a paint-like finish.</p>
        <div class="header-actions">
          <a href="/contact/?package=wrap-full" class="btn btn-accent">Request Wrap Quote</a>
        </div>
      </div>
      <div class="page-header-visual">
        <NeonCard>
          <div class="visual-wrapper">
            <img src="/images/ceramic-coating.png" alt="Vinyl Wrap Showcase" class="header-img" width="500" height="375" fetchpriority="high" />
          </div>
        </NeonCard>
      </div>
    </div>
  </section>

  <!-- Core Services Grid -->
  <section class="wrap-services-section section-padding">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="eyebrow">POPULAR PACKAGES</span>
        <h2>Choose Your Wrap Package</h2>
      </div>

      <div class="services-grid">
        {wrapServices.map((service, index) => (
          <div class="animate-on-scroll" style={`transition-delay: ${index * 100}ms`}>
            <NeonCard>
              <div class="service-card-body">
                <div class="service-icon-header">
                  <div class="service-icon-wrap">
                    <i class={service.icon}></i>
                  </div>
                  <h3>{service.name}</h3>
                </div>
                <p class="service-desc">{service.desc}</p>
                <div class="pricing-table">
                  <div class="pricing-row">
                    <span class="vehicle-class">Cars:</span>
                    <span class="price-val">{service.carsPrice}</span>
                  </div>
                  <div class="pricing-row">
                    <span class="vehicle-class">Trucks & SUVs:</span>
                    <span class="price-val">{service.trucksPrice}</span>
                  </div>
                </div>
                <a href="/contact/?package=wrap" class="btn btn-outline service-btn">Get Service Quote</a>
              </div>
            </NeonCard>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Small Accents & Partial Wraps -->
  <section class="partial-wraps-section section-padding">
    <div class="container partials-grid">
      <!-- Accents -->
      <div class="accents-column animate-on-scroll">
        <span class="eyebrow">DETAIL ACCENTS</span>
        <h2>Mirror & Pillar Accents</h2>
        <div class="accents-cards">
          {smallWraps.map(wrap => (
            <div class="glass-panel accent-card">
              <div class="accent-header">
                <h3>{wrap.name}</h3>
                <span class="accent-price">{wrap.price}</span>
              </div>
              <p>{wrap.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Partials -->
      <div class="partials-column animate-on-scroll delay-100">
        <NeonCard>
          <div class="partial-card-content">
            <span class="eyebrow">TAILORED CREATIONS</span>
            <h3>Partial & Custom Wraps</h3>
            <span class="partial-price">Custom Quote</span>
            <p class="partial-desc">Looking for custom graphics, stripes, or partial vehicle coverage? We design and install custom solutions tailored to your vehicle's lines and your styling goals.</p>
            
            <div class="examples-block">
              <h4>Common Examples:</h4>
              <ul class="examples-grid-list">
                {partialExamples.map(item => (
                  <li>
                    <i class="fa-solid fa-circle-check text-purple"></i>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            <a href="/contact/?package=wrap-custom" class="btn btn-outline partial-btn">Design Custom Project</a>
          </div>
        </NeonCard>
      </div>
    </div>
  </section>

  <!-- Wrap Removal Section -->
  <section class="removal-section section-padding">
    <div class="container">
      <div class="removal-content glass-panel animate-on-scroll">
        <span class="eyebrow">RESTORING ORIGINAL PAINT</span>
        <h2>Vehicle Wrap Removal</h2>
        <p>Old or damaged vinyl wraps can become hard to remove and can risk paint damage if not removed correctly. Our professional wrap removal services use controlled heat and specialized clean-up agents to safely pull old vinyl, clean adhesive residue, and restore your paint finish.</p>
        
        <div class="removal-pricing">
          <div class="removal-price-box">
            <h4>Cars</h4>
            <span class="price-tag">Starting at $899</span>
          </div>
          <div class="removal-price-box">
            <h4>Trucks & SUVs</h4>
            <span class="price-tag">Starting at $1,199</span>
          </div>
        </div>

        <div class="cta-buttons">
          <a href="/contact/?package=wrap-removal" class="btn btn-accent">Request Removal Estimate</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footnote pricing notice -->
  <section class="notice-section">
    <div class="container">
      <p class="pricing-notice">
        Pricing varies based on vehicle size, complexity, condition, existing wrap condition, film selection, and material requirements. Final pricing may vary after inspection.
      </p>
    </div>
  </section>
</Layout>

<style>
  /* Header section */
  .page-header-section {
    padding-top: 160px;
    padding-bottom: 60px;
    background: radial-gradient(circle at 50% 0%, rgba(139, 47, 141, 0.08) 0%, transparent 60%);
    border-bottom: 1px solid var(--color-hairline);
  }

  .page-header-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-xl);
    align-items: center;
    text-align: left;
  }

  .page-header-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .page-header-content h1 {
    font-size: 3rem;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.1;
  }

  .page-header-content p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0;
    text-align: left;
  }

  .header-actions {
    margin-top: var(--space-xs);
  }

  .page-header-visual {
    width: 100%;
  }

  .visual-wrapper {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 991px) {
    .page-header-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-lg);
    }

    .page-header-content {
      align-items: center;
    }

    .page-header-content p {
      text-align: center;
    }

    .page-header-visual {
      max-width: 480px;
      margin: 0 auto;
    }
  }

  /* Section Header */
  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-xxl) auto;
  }

  .section-header h2 {
    font-size: 2.25rem;
    color: var(--color-primary);
    margin-top: var(--space-xs);
  }

  .eyebrow {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-accent-neon);
    letter-spacing: 0.1em;
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .service-card-body {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: var(--space-md);
  }

  .service-icon-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .service-icon-wrap {
    width: 50px;
    height: 50px;
    border-radius: var(--radius-md);
    background: rgba(139, 47, 141, 0.1);
    border: 1px solid var(--color-hairline-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--color-accent-neon);
  }

  .service-icon-header h3 {
    font-size: 1.35rem;
    color: var(--color-primary);
    line-height: 1.2;
  }

  .service-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  .pricing-table {
    border-top: 1px solid var(--color-hairline);
    border-bottom: 1px solid var(--color-hairline);
    padding: var(--space-sm) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .pricing-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
  }

  .vehicle-class {
    color: var(--color-ink-muted);
  }

  .price-val {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-accent-neon);
  }

  .service-btn {
    width: 100%;
    justify-content: center;
  }

  /* Partials Section */
  .partials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .accents-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .accent-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .accent-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .accent-header h3 {
    font-size: 1.15rem;
    color: var(--color-primary);
  }

  .accent-price {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-accent-neon);
  }

  .accent-card p {
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0;
  }

  .partial-card-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .partial-price {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-accent-neon);
    text-shadow: 0 0 10px rgba(224, 76, 228, 0.3);
  }

  .partial-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  .examples-block h4 {
    color: var(--color-primary);
    font-size: 0.95rem;
    margin-bottom: var(--space-sm);
  }

  .examples-grid-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xs);
  }

  .examples-grid-list li {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .text-purple {
    color: var(--color-accent-neon);
    font-size: 0.85rem;
  }

  .partial-btn {
    width: 100%;
    justify-content: center;
  }

  /* Removal section */
  .removal-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
  }

  .removal-pricing {
    display: flex;
    gap: var(--space-xxl);
    margin: var(--space-md) 0;
  }

  .removal-price-box h4 {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: var(--space-xxs);
  }

  .removal-price-box .price-tag {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent-neon);
  }

  /* Notice styling */
  .notice-section {
    padding-bottom: var(--space-xxl);
    text-align: center;
  }

  .pricing-notice {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.5;
  }

  @media (max-width: 991px) {
    .services-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
    .partials-grid {
      grid-template-columns: 1fr;
    }
    .partials-column {
      max-width: 480px;
      margin: 0 auto;
      width: 100%;
    }
    .removal-pricing {
      flex-direction: column;
      gap: var(--space-md);
    }
  }
</style>
