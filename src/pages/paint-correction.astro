---
import Layout from '../layouts/Layout.astro';
import NeonCard from '../components/NeonCard.astro';
import BeforeAfter from '../components/BeforeAfter.astro';

const stages = [
  {
    title: "Enhancement Package",
    price: "From $300",
    time: "Requires 1 Day",
    desc: "Removes light swirls and restores gloss. Perfect for vehicles with light swirl marks, mild oxidation, and dull paint that need a noticeable refresh without extensive correction. This service dramatically boosts gloss, clarity, and reflection while improving approximately 40-60% of visible paint imperfections depending on paint condition.",
    defectRemoval: "40% - 60% paint defect removal",
    bestFor: [
      "Newer vehicles",
      "Light imperfections",
      "Increasing gloss and depth",
      "Improving overall appearance"
    ],
    improves: [
      "Light swirl marks",
      "Minor surface scratches",
      "Haze from automatic car washes",
      "Oxidation and faded appearance"
    ],
    btnText: "Get Enhancement Quote"
  },
  {
    title: "Correction Package",
    price: "From $500",
    time: "Requires 1.5 - 2 Days",
    desc: "Removes moderate defects and dramatically improves clarity. Designed for vehicles with moderate to heavy swirl marks, deeper scratches, holograms, oxidation, and neglected paint. This process uses a cutting stage followed by a refining polish stage to restore clarity and depth while maximizing paint correction safely. This service can typically remove 70-90% of paint imperfections depending on paint thickness and condition.",
    defectRemoval: "70% - 90% paint defect removal",
    bestFor: [
      "Vehicles with visible swirls and scratches",
      "Dark colored vehicles",
      "Heavily washed vehicles",
      "Customers wanting a major transformation"
    ],
    improves: [
      "Moderate to heavy swirl marks",
      "Water spot etching",
      "Oxidation",
      "Holograms/buffer trails",
      "Deeper imperfections",
      "Loss of gloss and clarity"
    ],
    btnText: "Get Correction Quote"
  },
  {
    title: "Restoration Package",
    price: "From $800",
    time: "Requires 2 - 3 Days",
    desc: "Maximum defect removal and gloss restoration. Our highest level correction process for enthusiasts and vehicles needing maximum restoration and refinement. This multi-stage process is designed to achieve the deepest gloss, highest clarity, and most refined finish possible while safely restoring the paint to near-showroom condition. The final finishing stage creates an ultra-refined finish with incredible depth, clarity, and reflection.",
    defectRemoval: "Near-Showroom restoration",
    bestFor: [
      "Black and dark colored vehicles",
      "Show cars & exotic vehicles",
      "Severe paint defects",
      "Customers seeking the absolute best finish possible"
    ],
    improves: [
      "Heavy swirl marks",
      "Severe oxidation",
      "Sanding marks",
      "Deep scratches (where safely possible)",
      "Heavy holograms",
      "Extreme paint dullness"
    ],
    btnText: "Get Restoration Quote"
  }
];
---

<Layout 
  title="Paint Correction & Swirl Restoration" 
  description="Restore a flawless mirror finish. Professional mobile Enhancement, Correction, and Restoration paint correction packages serving Valrico, Tampa, and Brandon FL."
>
  <!-- Page Header -->
  <section class="page-header-section">
    <div class="container page-header-grid animate-fade-in">
      <div class="page-header-content">
        <span class="eyebrow">PAINT RESTORATION</span>
        <h1>Paint Correction Services</h1>
        <p>Your vehicle’s paint goes through a lot. Automatic car washes, improper washing techniques, bird droppings, water spots, oxidation, and everyday wear slowly dull the finish and create scratches, swirl marks, and haze in the clear coat. Our process restores clarity, depth, gloss, and reflection.</p>
        <div class="header-actions">
          <a href="/contact?package=correction" class="btn btn-accent">Get A Quote</a>
        </div>
      </div>
      <div class="page-header-visual">
        <NeonCard>
          <div class="visual-wrapper">
            <img src="/images/paint-correction.png" alt="Paint Correction Showcase" class="header-img" width="500" height="375" fetchpriority="high" />
          </div>
        </NeonCard>
      </div>
    </div>
  </section>

  <!-- Interactive Comparison Slider -->
  <section class="comparison-slider-section section-padding">
    <div class="container comparison-grid">
      <div class="comparison-info animate-on-scroll">
        <span class="eyebrow">VISUAL PROOF</span>
        <h2>safely Restoring Paint Clarity</h2>
        <p>
          Our paint correction process is designed to safely restore clarity, depth, gloss, and reflection by machine polishing the paint and removing imperfections, not just temporarily hiding them.
        </p>
        <p>
          Every vehicle and paint condition is different, which is why we offer multiple levels of correction depending on the results you’re looking for.
        </p>
        <div class="guarantee-note">
          <i class="fa-solid fa-triangle-exclamation"></i>
          <div>
            <h4>Important Notes</h4>
            <p>Paint correction permanently removes defects within the clear coat where safely possible. Some deeper scratches or damage may be too deep to safely remove completely without compromising paint thickness.</p>
            <p style="margin-top: 8px;">Every correction service is finished with professional paint protection to enhance gloss and help maintain the results.</p>
          </div>
        </div>
      </div>
      
      <div class="slider-wrapper animate-on-scroll delay-100">
        <BeforeAfter />
      </div>
    </div>
  </section>

  <!-- Stages Details -->
  <section class="stages-section section-padding">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="eyebrow">OUR LEVELS</span>
        <h2>Choose Your Level of Correction</h2>
      </div>
      
      <div class="stages-grid">
        {stages.map((stage, index) => (
          <div class="animate-on-scroll" style={`transition-delay: ${index * 100}ms`}>
            <NeonCard>
              <div class="stage-card-body">
                <div class="stage-header">
                  <h3>{stage.title}</h3>
                  <span class="stage-price">{stage.price}</span>
                  <span class="stage-time"><i class="fa-solid fa-clock"></i> {stage.time}</span>
                </div>
                
                <p class="stage-desc">{stage.desc}</p>
                
                <div class="stage-specs">
                  <div class="spec-line">
                    <span class="spec-label">DEFECT REMOVAL</span>
                    <span class="spec-value highlight-purple">{stage.defectRemoval}</span>
                  </div>
                  
                  <div class="spec-line">
                    <span class="spec-label">BEST FOR</span>
                    <ul class="spec-list">
                      {stage.bestFor.map(item => (
                        <li><i class="fa-solid fa-angle-right"></i> {item}</li>
                      ))}
                    </ul>
                  </div>

                  <div class="spec-line">
                    <span class="spec-label">WHAT IT CAN IMPROVE</span>
                    <ul class="spec-list">
                      {stage.improves.map(item => (
                        <li><i class="fa-solid fa-circle-check"></i> {item}</li>
                      ))}
                    </ul>
                  </div>
                </div>
                
                <a href={`/contact?package=correction`} class="btn btn-outline stage-btn">{stage.btnText}</a>
              </div>
            </NeonCard>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Step Breakdown -->
  <section class="breakdown-section section-padding">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="eyebrow">PRECISION WORKFLOW</span>
        <h2>How We Correct Paint Safely</h2>
      </div>
      
      <div class="workflow-steps-grid">
        <div class="workflow-step glass-panel animate-on-scroll">
          <span class="w-step-num">01</span>
          <h4>Multi-Stage Clean & Decon</h4>
          <p>We strip old waxes, perform a foam bath, chemical iron remover, and clay bar treatment to ensure the paint has zero contaminants before polishing.</p>
        </div>
        
        <div class="workflow-step glass-panel animate-on-scroll delay-100">
          <span class="w-step-num">02</span>
          <h4>Paint Thickness Measuring</h4>
          <p>We measure clear coat thickness in microns using digital gauges to ensure safe leveling and map out deep scratches before starting machine compounding.</p>
        </div>
        
        <div class="workflow-step glass-panel animate-on-scroll delay-200">
          <span class="w-step-num">03</span>
          <h4>Machine Correction</h4>
          <p>Using dual-action orbital polishers and premium foam/wool pads, we gently correct defects using decreasing compound grits for a swirl-free finish.</p>
        </div>
        
        <div class="workflow-step glass-panel animate-on-scroll delay-300">
          <span class="w-step-num">04</span>
          <h4>Polish & Protection</h4>
          <p>Every correction service is finished with professional paint protection to enhance gloss and help maintain the results.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Header section */
  .page-header-section {
    padding-top: 160px;
    padding-bottom: 60px;
    background: radial-gradient(circle at 50% 0%, rgba(139, 47, 141, 0.08) 0%, transparent 60%);
    border-bottom: 1px solid var(--color-hairline);
  }

  .page-header-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-xl);
    align-items: center;
    text-align: left;
  }

  .page-header-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .page-header-content h1 {
    font-size: 3rem;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.1;
  }

  .page-header-content p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0;
    text-align: left;
  }

  .header-actions {
    margin-top: var(--space-xs);
  }

  .page-header-visual {
    width: 100%;
  }

  .visual-wrapper {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 991px) {
    .page-header-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-lg);
    }

    .page-header-content {
      align-items: center;
    }

    .page-header-content p {
      text-align: center;
    }

    .page-header-visual {
      max-width: 480px;
      margin: 0 auto;
    }
  }

  /* Comparison Grid */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-xxl);
    align-items: center;
  }

  .comparison-info h2 {
    font-size: 2.25rem;
    color: var(--color-primary);
    margin: var(--space-xs) 0 var(--space-md) 0;
  }

  .comparison-info p {
    margin-bottom: var(--space-md);
    line-height: 1.6;
  }

  .guarantee-note {
    display: flex;
    gap: var(--space-md);
    background: rgba(139, 47, 141, 0.05);
    border: 1px solid var(--color-hairline-accent);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    margin-top: var(--space-lg);
  }

  .guarantee-note i {
    color: var(--color-accent-neon);
    font-size: 1.25rem;
    margin-top: 3px;
  }

  .guarantee-note h4 {
    color: var(--color-primary);
    font-size: 0.95rem;
    margin-bottom: var(--space-xxs);
  }

  .guarantee-note p {
    font-size: 0.8rem;
    line-height: 1.4;
    margin: 0;
  }

  /* Section Header */
  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-xxl) auto;
  }

  .section-header h2 {
    font-size: 2.25rem;
    color: var(--color-primary);
    margin-top: var(--space-xs);
  }

  .eyebrow {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-accent-neon);
    letter-spacing: 0.1em;
  }

  /* Stages Grid */
  .stages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .stage-card-body {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: var(--space-md);
  }

  .stage-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xxs);
    border-bottom: 1px solid var(--color-hairline);
    padding-bottom: var(--space-md);
  }

  .stage-header h3 {
    font-size: 1.35rem;
    color: var(--color-primary);
    line-height: 1.2;
  }

  .stage-price {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-accent-neon);
    text-shadow: 0 0 10px rgba(224, 76, 228, 0.3);
  }

  .stage-time {
    font-size: 0.8rem;
    color: var(--color-ink-muted);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .stage-time i {
    color: var(--color-accent-neon);
  }

  .stage-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0;
  }

  .stage-specs {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    flex-grow: 1;
    margin: var(--space-xs) 0;
  }

  .spec-line {
    display: flex;
    flex-direction: column;
    gap: var(--space-xxs);
  }

  .spec-label {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-ink-muted);
    letter-spacing: 0.05em;
  }

  .spec-value {
    font-size: 0.85rem;
    color: var(--color-primary);
    line-height: 1.4;
  }

  .spec-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .spec-list li {
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }

  .spec-list li i {
    color: var(--color-accent-neon);
    margin-top: 3px;
    font-size: 0.8rem;
  }

  .highlight-purple {
    color: var(--color-accent-neon);
    font-weight: 600;
    text-shadow: 0 0 5px rgba(224, 76, 228, 0.2);
  }

  .stage-btn {
    width: 100%;
    justify-content: center;
  }

  /* Workflow Steps Grid */
  .workflow-steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .workflow-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    position: relative;
    padding: var(--space-xl) var(--space-md);
  }

  .w-step-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    color: rgba(139, 47, 141, 0.2);
    line-height: 1;
  }

  .workflow-step h4 {
    color: var(--color-primary);
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .workflow-step p {
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 991px) {
    .comparison-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    .stages-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
    .workflow-steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 575px) {
    .workflow-steps-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
