---
import Layout from '../../layouts/Layout.astro';
import NeonCard from '../../components/NeonCard.astro';

export async function getStaticPaths() {
  return [
    {
      params: { area: 'valrico-fl' },
      props: {
        city: "Valrico",
        title: "Valrico Mobile Auto Detailing",
        description: "Premium mobile auto detailing, paint correction, and ceramic coatings delivered to your driveway in Valrico, FL.",
        slug: "valrico-fl",
        metaDesc: "We provide rapid-response mobile detailing, paint correction, and ceramic coatings to all residential and commercial addresses in Valrico."
      }
    },
    {
      params: { area: 'tampa-fl' },
      props: {
        city: "Tampa",
        title: "Tampa Mobile Auto Detailing",
        description: "Premium mobile auto detailing, paint correction, and ceramic coatings delivered to your driveway in Tampa, FL.",
        slug: "tampa-fl",
        metaDesc: "We provide rapid-response mobile detailing, paint correction, and ceramic coatings to all residential and commercial addresses in Tampa."
      }
    },
    {
      params: { area: 'brandon-fl' },
      props: {
        city: "Brandon",
        title: "Brandon Mobile Auto Detailing",
        description: "Premium mobile auto detailing, paint correction, and ceramic coatings delivered to your driveway in Brandon, FL.",
        slug: "brandon-fl",
        metaDesc: "We provide rapid-response mobile detailing, paint correction, and ceramic coatings to all residential and commercial addresses in Brandon."
      }
    },
    {
      params: { area: 'st-petersburg-fl' },
      props: {
        city: "St. Petersburg",
        title: "St. Petersburg Mobile Auto Detailing",
        description: "Premium mobile auto detailing, paint correction, and ceramic coatings delivered to your driveway in St. Petersburg, FL.",
        slug: "st-petersburg-fl",
        metaDesc: "We provide rapid-response mobile detailing, paint correction, and ceramic coatings to all residential and commercial addresses in St. Petersburg."
      }
    },
    {
      params: { area: 'clearwater-fl' },
      props: {
        city: "Clearwater",
        title: "Clearwater Mobile Auto Detailing",
        description: "Premium mobile auto detailing, paint correction, and ceramic coatings delivered to your driveway in Clearwater, FL.",
        slug: "clearwater-fl",
        metaDesc: "We provide rapid-response mobile detailing, paint correction, and ceramic coatings to all residential and commercial addresses in Clearwater."
      }
    },
    {
      params: { area: 'lakeland-fl' },
      props: {
        city: "Lakeland",
        title: "Lakeland Mobile Auto Detailing",
        description: "Premium mobile auto detailing, paint correction, and ceramic coatings delivered to your driveway in Lakeland, FL.",
        slug: "lakeland-fl",
        metaDesc: "We provide rapid-response mobile detailing, paint correction, and ceramic coatings to all residential and commercial addresses in Lakeland."
      }
    },
    {
      params: { area: 'spring-hill-fl' },
      props: {
        city: "Spring Hill",
        title: "Spring Hill Mobile Auto Detailing",
        description: "Premium mobile auto detailing, paint correction, and ceramic coatings delivered to your driveway in Spring Hill, FL.",
        slug: "spring-hill-fl",
        metaDesc: "We provide rapid-response mobile detailing, paint correction, and ceramic coatings to all residential and commercial addresses in Spring Hill."
      }
    }
  ];
}

const { city, title, description, slug, metaDesc } = Astro.props;
const mapQuery = encodeURIComponent(`${city}, FL`);
---

<Layout title={title} description={description}>
  <!-- JSON-LD SEO Schema -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AutoBodyShop",
    "name": "Royalty Auto Care LLC",
    "image": "https://royaltyautocare.net/after-detail.png",
    "@id": "https://royaltyautocare.net",
    "url": "https://royaltyautocare.net/",
    "telephone": "(813) 539-4723",
    "email": "rroyaltyautocare@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Valrico",
      "addressRegion": "FL",
      "addressCountry": "US"
    },
    "areaServed": [
      { "@type": "City", "name": "Valrico", "sameAs": "https://en.wikipedia.org/wiki/Valrico,_Florida" },
      { "@type": "City", "name": "Tampa", "sameAs": "https://en.wikipedia.org/wiki/Tampa,_Florida" },
      { "@type": "City", "name": "Brandon", "sameAs": "https://en.wikipedia.org/wiki/Brandon,_Florida" },
      { "@type": "City", "name": "St. Petersburg", "sameAs": "https://en.wikipedia.org/wiki/St._Petersburg,_Florida" },
      { "@type": "City", "name": "Clearwater", "sameAs": "https://en.wikipedia.org/wiki/Clearwater,_Florida" },
      { "@type": "City", "name": "Lakeland", "sameAs": "https://en.wikipedia.org/wiki/Lakeland,_Florida" },
      { "@type": "City", "name": "Spring Hill", "sameAs": "https://en.wikipedia.org/wiki/Spring_Hill,_Florida" }
    ],
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        "opens": "08:00",
        "closes": "18:00"
      }
    ],
    "priceRange": "$$"
  })} />

  <!-- Hero Section -->
  <section class="area-hero">
    <img src={`/images/${slug}.jpg`} alt={`Mobile auto detailing service area in ${city}, FL`} class="hero-bg-img" loading="eager" width="1920" height="1080" fetchpriority="high" />
    <div class="hero-overlay"></div>
    <div class="container hero-content text-center">
      <h1>Auto Detailing in <span class="text-purple">{city}, FL.</span></h1>
      <p>Premium mobile detailing delivered straight to your home or office in {city}. Experience the Royal Treatment today.</p>
      <div class="hero-buttons">
        <a href="/contact" class="btn btn-accent"><i class="fa-solid fa-calendar-check"></i> Book Now</a>
        <a href="tel:+18135394723" class="btn btn-outline"><i class="fa-solid fa-phone"></i> Call (813) 539-4723</a>
      </div>
    </div>
  </section>

  <!-- Local Experts Section -->
  <section class="experts-section section-padding">
    <div class="container experts-grid">
      <div class="experts-info animate-on-scroll">
        <span class="eyebrow">LOCAL EXPERTS</span>
        <h2>Your Local {city} Detailing Experts</h2>
        <p>
          As a dedicated service area, <strong>{city}, FL</strong> holds a special place for Royalty Auto Care. {metaDesc} We traverse the entire area to provide the highest standard of mobile auto detailing, paint correction, and ceramic coatings.
        </p>
        <p>
          Whether you need a deep interior extraction after taking the kids to the park, or a multi-stage paint correction and ceramic coating to protect your vehicle from the intense Florida sun, we have the expertise and the mobile rig to get it done right in your driveway.
        </p>
        <ul class="experts-bullets">
          <li><i class="fa-solid fa-check text-purple"></i> We supply our own spot-free water & power.</li>
          <li><i class="fa-solid fa-check text-purple"></i> Rapid response detailing for the {city} community.</li>
          <li><i class="fa-solid fa-check text-purple"></i> 5-Star Rated strictly on premium quality.</li>
        </ul>
      </div>

      <div class="experts-visual animate-on-scroll delay-100">
        <NeonCard>
          <div class="rig-info-card">
            <h3>Mobile Service in {city}</h3>
            <p>
              Royalty Auto Care provides fully self-contained mobile detailing throughout <strong>{city}</strong>. We don't need to hook up to your water or power — our mobile rig is equipped with a quiet generator and a large spot-free water tank, allowing us to detail your car at your home, office, or local address.
            </p>
            <a href="/auto-detailing" class="btn btn-primary rig-btn">View Packages</a>
          </div>
        </NeonCard>
      </div>
    </div>
  </section>

  <!-- Core Services Section -->
  <section class="services-section section-padding">
    <div class="container animate-on-scroll">
      <div class="section-header text-center">
        <span class="eyebrow">EXPERT CAR CARE</span>
        <h2>Premium Services in {city}</h2>
      </div>

      <div class="services-links-grid">
        <div class="glass-panel text-center service-link-card">
          <h4>Mobile Detailing</h4>
          <p>From interior steam cleaning to full exterior clay bar treatments in {city}.</p>
          <a href="/auto-detailing" class="text-purple link-action">Learn More <i class="fa-solid fa-arrow-right"></i></a>
        </div>

        <div class="glass-panel text-center service-link-card">
          <h4>Paint Correction</h4>
          <p>Remove swirls and restore the mirror finish on your vehicle right here in {city}.</p>
          <a href="/paint-correction" class="text-purple link-action">Learn More <i class="fa-solid fa-arrow-right"></i></a>
        </div>

        <div class="glass-panel text-center service-link-card">
          <h4>Ceramic Coating</h4>
          <p>The ultimate long-term protection against the Florida elements for {city} drivers.</p>
          <a href="/ceramic-coating" class="text-purple link-action">Learn More <i class="fa-solid fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Local Map Section -->
  <section class="map-section section-padding">
    <div class="container">
      <div class="section-header text-center animate-on-scroll">
        <span class="eyebrow">OUR COVERAGE</span>
        <h2>Our {city} Service Area</h2>
      </div>
      <div class="map-wrapper animate-on-scroll">
        <iframe 
          src={`https://maps.google.com/maps?q=${mapQuery}&t=&z=11&ie=UTF8&iwloc=&output=embed`} 
          width="100%" 
          height="450" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .area-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 120px;
  }

  .hero-bg-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to bottom, rgba(6, 3, 6, 0.5) 0%, rgba(6, 3, 6, 0.9) 100%);
    z-index: 2;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    max-width: 800px;
  }

  .hero-content h1 {
    font-size: 3.5rem;
    margin-bottom: var(--space-md);
    text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.8);
  }

  .hero-content p {
    font-size: 1.25rem;
    color: var(--color-primary);
    margin-bottom: var(--space-xl);
    text-shadow: 1px 1px 6px rgba(0, 0, 0, 0.8);
  }

  .hero-buttons {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
  }

  .text-purple {
    color: var(--color-accent-neon);
    text-shadow: 0 0 15px rgba(224, 76, 228, 0.4);
  }

  /* Experts Section */
  .experts-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-xxl);
    align-items: center;
  }

  .eyebrow {
    color: var(--color-accent-neon);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .experts-info h2 {
    font-size: 2.5rem;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .experts-info p {
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .experts-bullets {
    list-style: none;
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .experts-bullets li {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: 1.05rem;
    font-weight: 500;
  }

  .rig-info-card {
    padding: var(--space-xs);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .rig-info-card h3 {
    font-size: 1.5rem;
    border-left: 4px solid var(--color-accent-neon);
    padding-left: var(--space-md);
    color: var(--color-primary);
  }

  .rig-info-card p {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .rig-btn {
    width: 100%;
  }

  /* Core Services Section */
  .services-section {
    background: linear-gradient(to bottom, var(--color-canvas), var(--color-surface-1));
  }

  .section-header {
    margin-bottom: var(--space-xxl);
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-top: var(--space-xs);
  }

  .services-links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-xl);
  }

  .service-link-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: center;
  }

  .service-link-card h4 {
    font-size: 1.35rem;
    color: var(--color-primary);
  }

  .service-link-card p {
    font-size: 0.95rem;
    line-height: 1.6;
    flex-grow: 1;
  }

  .link-action {
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    transition: var(--transition-fast);
  }

  .link-action:hover {
    color: var(--color-primary);
    transform: translateX(4px);
  }

  /* Map Section */
  .map-wrapper {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-hairline);
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  @media (max-width: 991px) {
    .experts-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 767px) {
    .hero-content h1 {
      font-size: 2.5rem;
    }
    
    .hero-buttons {
      flex-direction: column;
    }
    
    .experts-info h2 {
      font-size: 2rem;
    }
  }
</style>
