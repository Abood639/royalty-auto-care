---
import Layout from '../layouts/Layout.astro';
import NeonCard from '../components/NeonCard.astro';

const plans = [
  {
    name: "Weekly Maintenance",
    desc: "Designed for clients who want their vehicle looking consistently perfect at all times.",
    icon: "fa-solid fa-calendar-day",
    bestFor: [
      "Luxury vehicles",
      "Daily drivers",
      "Busy professionals",
      "Clients who never want buildup"
    ]
  },
  {
    name: "Bi-Weekly Maintenance",
    desc: "Our most popular maintenance option. A perfect balance between cleanliness, protection, and long-term upkeep.",
    icon: "fa-solid fa-calendar-week",
    bestFor: [
      "Most daily driven vehicles",
      "Families",
      "Luxury SUVs and trucks",
      "Clients wanting consistent maintenance without weekly visits"
    ],
    featured: true
  },
  {
    name: "Monthly Maintenance",
    desc: "A great option for clients wanting regular upkeep while maintaining flexibility.",
    icon: "fa-solid fa-calendar",
    bestFor: [
      "Lower mileage vehicles",
      "Garage-kept vehicles",
      "Clients wanting periodic professional maintenance"
    ]
  },
  {
    name: "Every 2 Months",
    desc: "Designed for vehicles that still need routine professional care but do not require frequent visits.",
    icon: "fa-solid fa-calendar-minus",
    bestFor: [
      "Secondary vehicles",
      "Weekend vehicles",
      "Light-use vehicles"
    ]
  }
];

const inclusions = [
  "Safe hand wash",
  "Wheel and tire cleaning",
  "Interior wipe down",
  "Thorough vacuuming",
  "Window cleaning",
  "Ceramic sealant maintenance",
  "Tire dressing",
  "Touch-up cleaning of high-contact areas"
];

const fleetVehicles = [
  { type: "Company trucks", icon: "fa-solid fa-truck" },
  { type: "Work vans", icon: "fa-solid fa-van-shuttle" },
  { type: "Realtor vehicles", icon: "fa-solid fa-key" },
  { type: "Service vehicles", icon: "fa-solid fa-wrench" },
  { type: "Business fleets", icon: "fa-solid fa-briefcase" },
  { type: "Commercial vehicles", icon: "fa-solid fa-truck-flatbed" }
];

const fleetBenefits = [
  "Consistent professional appearance",
  "Scheduled maintenance options",
  "Mobile convenience",
  "Custom fleet plans available",
  "Improved brand presentation"
];
---

<Layout 
  title="Maintenance Plans & Fleet Services" 
  description="Keep your car perfect year-round with weekly, bi-weekly, or monthly maintenance plans and professional commercial fleet washing in Valrico & Tampa FL."
>
  <!-- Page Header -->
  <section class="page-header-section">
    <div class="container page-header-grid animate-fade-in">
      <div class="page-header-content">
        <span class="eyebrow">ROUTINE UPKEEP</span>
        <h1>Royalty Care Maintenance Plans</h1>
        <p>Designed for clients who want their vehicles consistently clean, protected, and maintained year-round without allowing buildup to get out of control. Routine maintenance preserves paint, interior materials, and long-term value.</p>
        <div class="header-actions">
          <a href="/contact?package=maintenance" class="btn btn-accent">Request Plan Details</a>
        </div>
      </div>
      <div class="page-header-visual">
        <NeonCard>
          <div class="visual-wrapper">
            <img src="/images/home.png" alt="Maintenance Detailing Showcase" class="header-img" width="500" height="375" fetchpriority="high" />
          </div>
        </NeonCard>
      </div>
    </div>
  </section>

  <!-- Inclusions Section -->
  <section class="inclusions-section section-padding">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="eyebrow">WHAT'S INCLUDED</span>
        <h2>Every Maintenance Service Includes</h2>
        <p>A comprehensive routine checklist executed professionally to keep your previous detailing work fresh and protected.</p>
      </div>

      <div class="inclusions-grid animate-on-scroll">
        {inclusions.map(inc => (
          <div class="inclusion-item glass-panel">
            <i class="fa-solid fa-circle-check inclusion-icon"></i>
            <span>{inc}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Plans Tiers Section -->
  <section class="plans-section section-padding">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="eyebrow">FLEXIBLE FREQUENCY</span>
        <h2>Choose Your Upkeep Schedule</h2>
      </div>

      <div class="plans-grid">
        {plans.map((plan, index) => (
          <div class="animate-on-scroll" style={`transition-delay: ${index * 100}ms`}>
            {plan.featured ? (
              <NeonCard class="featured-plan-card">
                <div class="plan-header">
                  <span class="featured-badge">MOST POPULAR</span>
                  <div class="plan-title-row">
                    <i class={`${plan.icon} plan-icon icon-glow`}></i>
                    <h3>{plan.name}</h3>
                  </div>
                  <p>{plan.desc}</p>
                </div>
                <div class="plan-best-for">
                  <h4>Ideal For:</h4>
                  <ul>
                    {plan.bestFor.map(item => (
                      <li><i class="fa-solid fa-circle-check icon-glow"></i> {item}</li>
                    ))}
                  </ul>
                </div>
                <a href="/contact?package=maintenance-biweekly" class="btn btn-accent plan-btn">Select Bi-Weekly Plan</a>
              </NeonCard>
            ) : (
              <div class="glass-panel standard-plan-card">
                <div class="plan-header">
                  <div class="plan-title-row">
                    <i class={`${plan.icon} plan-icon`}></i>
                    <h3>{plan.name}</h3>
                  </div>
                  <p>{plan.desc}</p>
                </div>
                <div class="plan-best-for">
                  <h4>Ideal For:</h4>
                  <ul>
                    {plan.bestFor.map(item => (
                      <li><i class="fa-solid fa-circle-check"></i> {item}</li>
                    ))}
                  </ul>
                </div>
                <a href="/contact?package=maintenance" class="btn btn-outline plan-btn">Select Plan</a>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Fleet Services Section -->
  <section class="fleet-section section-padding">
    <div class="container fleet-grid-container">
      <div class="fleet-info animate-on-scroll">
        <span class="eyebrow">COMMERCIAL SOLUTIONS</span>
        <h2>Fleet Vehicle Services</h2>
        <p>Keep your company vehicles clean, presentable, and professional. A pristine fleet reflects directly on your business values and leaves a lasting, positive impression on your clients and customers.</p>
        
        <div class="fleet-benefits-box">
          <h4>Fleet Service Benefits:</h4>
          <ul class="fleet-benefits-list">
            {fleetBenefits.map(benefit => (
              <li>
                <i class="fa-solid fa-circle-check benefit-check"></i>
                <span>{benefit}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="fleet-vehicles-box glass-panel animate-on-scroll delay-100">
        <h3>Available Fleet Types</h3>
        <p style="margin-bottom: var(--space-lg); font-size: 0.9rem; color: var(--color-ink-muted);">We customize washing and detailing routines for all types of company operations:</p>
        <div class="fleet-vehicles-grid">
          {fleetVehicles.map(vehicle => (
            <div class="fleet-vehicle-card">
              <i class={vehicle.icon}></i>
              <span>{vehicle.type}</span>
            </div>
          ))}
        </div>
        <a href="/contact?package=fleet" class="btn btn-accent fleet-btn" style="margin-top: var(--space-lg); width: 100%; justify-content: center;">Discuss Fleet Plans</a>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="cta-section section-padding">
    <div class="container">
      <div class="cta-content glass-panel animate-on-scroll">
        <h2>Restore First, Maintain For Life</h2>
        <p>Note: Maintenance plans are exclusively available to clients who have received a Full Detail, Paint Correction, or Ceramic Coating service within the last 60 days to establish a baseline of cleanliness.</p>
        <div class="cta-buttons">
          <a href="tel:+18135394723" class="btn btn-primary"><i class="fa-solid fa-phone"></i> (813) 539-4723</a>
          <a href="/contact" class="btn btn-accent">Apply for Maintenance</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Header section */
  .page-header-section {
    padding-top: 160px;
    padding-bottom: 60px;
    background: radial-gradient(circle at 50% 0%, rgba(139, 47, 141, 0.08) 0%, transparent 60%);
    border-bottom: 1px solid var(--color-hairline);
  }

  .page-header-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-xl);
    align-items: center;
    text-align: left;
  }

  .page-header-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .page-header-content h1 {
    font-size: 3rem;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.1;
  }

  .page-header-content p {
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0;
    text-align: left;
  }

  .header-actions {
    margin-top: var(--space-xs);
  }

  .page-header-visual {
    width: 100%;
  }

  .visual-wrapper {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .header-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 991px) {
    .page-header-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-lg);
    }

    .page-header-content {
      align-items: center;
    }

    .page-header-content p {
      text-align: center;
    }

    .page-header-visual {
      max-width: 480px;
      margin: 0 auto;
    }
  }

  /* Section Header */
  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-xxl) auto;
  }

  .section-header h2 {
    font-size: 2.25rem;
    color: var(--color-primary);
    margin-top: var(--space-xs);
  }

  .eyebrow {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-accent-neon);
    letter-spacing: 0.1em;
  }

  /* Inclusions Grid */
  .inclusions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
  }

  .inclusion-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    border: 1px solid var(--color-hairline);
    transition: var(--transition-fast);
  }

  .inclusion-item:hover {
    border-color: var(--color-accent-neon);
    background: rgba(139, 47, 141, 0.05);
    transform: translateY(-2px);
  }

  .inclusion-icon {
    color: var(--color-accent-neon);
    font-size: 1.15rem;
    flex-shrink: 0;
  }

  .inclusion-item span {
    font-size: 0.9rem;
    color: var(--color-primary);
    font-weight: 500;
  }

  /* Plans Grid */
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .featured-plan-card, .standard-plan-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .standard-plan-card {
    padding: var(--space-xl) var(--space-lg);
  }

  .plan-header {
    margin-bottom: var(--space-lg);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .plan-title-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .plan-icon {
    font-size: 1.5rem;
    color: var(--color-ink-muted);
  }

  .icon-glow {
    color: var(--color-accent-neon);
    text-shadow: 0 0 8px rgba(224, 76, 228, 0.4);
  }

  .featured-badge {
    position: absolute;
    top: -30px;
    right: 0;
    background: var(--color-accent);
    color: var(--color-primary);
    border: 1px solid var(--color-accent-neon);
    font-size: 0.7rem;
    font-weight: 700;
    font-family: var(--font-display);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    box-shadow: 0 0 10px rgba(224, 76, 228, 0.3);
  }

  .plan-header h3 {
    font-size: 1.25rem;
    color: var(--color-primary);
    margin: 0;
  }

  .plan-header p {
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0;
    color: var(--color-ink-muted);
  }

  .plan-best-for {
    margin-bottom: var(--space-xl);
    flex-grow: 1;
  }

  .plan-best-for h4 {
    font-size: 0.9rem;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
    font-family: var(--font-display);
  }

  .plan-best-for ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0;
    margin: 0;
  }

  .plan-best-for li {
    display: flex;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-ink-muted);
    align-items: flex-start;
  }

  .plan-best-for li i {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    margin-top: 2px;
  }

  .plan-btn {
    width: 100%;
    justify-content: center;
  }

  /* Fleet Section styling */
  .fleet-section {
    border-top: 1px solid var(--color-hairline);
    background: radial-gradient(circle at 50% 100%, rgba(139, 47, 141, 0.04) 0%, transparent 60%);
  }

  .fleet-grid-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xxl);
    align-items: center;
  }

  .fleet-info h2 {
    font-size: 2.25rem;
    color: var(--color-primary);
    margin: var(--space-xs) 0 var(--space-md) 0;
  }

  .fleet-info p {
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .fleet-benefits-box h4 {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
    font-family: var(--font-display);
    font-weight: 600;
  }

  .fleet-benefits-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: 0;
    margin: 0;
  }

  .fleet-benefits-list li {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
  }

  .benefit-check {
    color: var(--color-accent-neon);
    margin-top: 3px;
    font-size: 0.85rem;
  }

  .fleet-vehicles-box {
    padding: var(--space-xl);
  }

  .fleet-vehicles-box h3 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: var(--space-xxs);
  }

  .fleet-vehicles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .fleet-vehicle-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xs);
    padding: var(--space-sm);
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-md);
    transition: var(--transition-fast);
  }

  .fleet-vehicle-card:hover {
    border-color: var(--color-accent-neon);
    background: rgba(139, 47, 141, 0.05);
    transform: translateY(-2px);
  }

  .fleet-vehicle-card i {
    font-size: 1.5rem;
    color: var(--color-accent-neon);
    text-shadow: 0 0 8px rgba(224, 76, 228, 0.2);
  }

  .fleet-vehicle-card span {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* Bottom CTA */
  .cta-content {
    text-align: center;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .cta-content h2 {
    font-size: 2rem;
    color: var(--color-primary);
  }

  .cta-content p {
    font-size: 1rem;
    max-width: 600px;
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-md);
  }

  @media (max-width: 1199px) {
    .inclusions-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .plans-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 991px) {
    .fleet-grid-container {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 767px) {
    .inclusions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .plans-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
    .fleet-vehicles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .inclusions-grid {
      grid-template-columns: 1fr;
    }
    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }
    .cta-buttons a {
      width: 100%;
    }
  }
</style>
